# ---------------------------------------------------
# 1. API Keys and Secrets (CRITICAL)
# ---------------------------------------------------
# Never push your actual environment variables. 
# Keep your Groq API keys and other secrets in here.
.env
.env.example


# ---------------------------------------------------
# 2. Virtual Environments (Heavy Libraries)
# ---------------------------------------------------
# This ignores the actual downloaded code for PyTorch, 
# TensorFlow, etc., keeping your repo lightweight.
venv/
env/

# ---------------------------------------------------
# 3. Heavy ML Models & Vectorizers
# ---------------------------------------------------
# This ignores the entire models folder and its contents
models/

# Catch-all for model files anywhere in the project
*.h5
*.pkl
*.pt
*.pth
*.safetensors
*.bin
# ---------------------------------------------------
# 4. Datasets
# ---------------------------------------------------
# GitHub has strict file limits. Ignore your raw/fake data.
data/*.csv
*.csv

# ---------------------------------------------------
# 5. Python Caches and Compiled Code
# ---------------------------------------------------
# Ignore automatically generated cache folders.
__pycache__/
*.py[cod]
*$py.class

# ---------------------------------------------------
# 6. IDE / OS System Files
# ---------------------------------------------------
.vscode/
.DS_Store